{
  "name": "@hyperledger/cacti-plugin-copm-fabric",
  "version": "0.0.1",
  "description": "Cacti Common Operators - Fabric",
  "scripts": {
    "test": "yarn run --top-level test:jest:all ./src/test/typescript/*/*.test.ts",
    "proto": "yarn run proto:copy; yarn run proto:connectrpc",
    "proto:copy": "/bin/bash ../cacti-copm-core/export-protos.sh . fabric",
    "proto:connectrpc": "yarn run buf generate --template=./buf.gen.yaml ./src/main/proto/generated/openapi"
  },
  "dependencies": {
    "@bufbuild/buf": "1.30.0",
    "@bufbuild/protobuf": "1.10.0",
    "@connectrpc/connect": "^1.4.0",
    "@hyperledger/cacti-copm-core": "workspace:^"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "1.8.0",
    "@connectrpc/connect-node": "^1.4.0",
    "@connectrpc/protoc-gen-connect-es": "^1.4.0",
    "@openapitools/openapi-generator-cli": "2.13.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperledger/cacti.git"
  },
  "author": "Jennifer Bell",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/hyperledger/cacti/issues"
  },
  "homepage": "https://github.com/hyperledger/cacti#readme"
}
